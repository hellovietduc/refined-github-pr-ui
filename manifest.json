{
  "manifest_version": 3,
  "name": "refined-github-pr-ui",
  "version": "1.0.0",
  "description": "Filter bot comments on GitHub PR pages. Hides bot noise, shows human feedback.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*/pull/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage"],
  "host_permissions": ["https://github.com/*/pull/*"]
}
